generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  STAFF
  ADMIN
  MANAGER
  CLIENT
  SUB_ADMIN
  SCHEDULER
}

enum EventStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ShiftStatus {
  PENDING
  CONFIRMED
  REJECTED
  YET_TO_START
  TRAVEL_TO_VENUE // Staff started travel (Uber-like flow)
  ARRIVED // Staff arrived at venue
  ONGOING
  IN_PROGRESS
  BREAK
  COMPLETED
  TRAVEL_HOME // Staff traveling home
}

// ─── Core Identity ───────────────────────────────────────────────────────────

model User {
  id             String    @id @default(uuid())
  name           String
  email          String    @unique
  phone          String?
  password       String
  role           Role
  avatar         String?
  bio            String?
  dob            DateTime?
  gender         String?
  address        String?
  city           String?
  state          String?
  zipCode        String?
  country        String?
  isActive       Boolean   @default(true)
  lastLogin      DateTime?
  loggedOutAllAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Profiles
  staffProfile  StaffProfile?
  clientProfile ClientProfile?

  // Events & Shifts
  managedEvents Event[] @relation("EventManager")
  shifts        Shift[]

  // HR
  applications        Application[]
  certifications      Certification[] @relation("StaffCertifications")
  interviews          Interview[]
  interviewsConducted Interview[]     @relation("Interviewer")
  documents           Document[]
  assessments         Assessment[]    @relation("CandidateAssessments")

  // Finance
  approvedTimesheets Timesheet[]  @relation("TimesheetApprover")
  payrollsProcessed  PayrollRun[] @relation("PayrollProcessor")
  timesheets         Timesheet[]

  // Operations
  incidentsReported IncidentReport[] @relation("IncidentReporter")

  // Chat & Notifications
  conversations ConversationParticipant[]
  messagesSent  Message[]
  notifications Notification[]

  // Favorites
  favoriteStaffEntries FavoriteStaff[] @relation("ClientFavorites")
  favoritedByClients   FavoriteStaff[] @relation("StaffFavorited")

  // Settings
  preferences UserPreferences?
  loginLogs   LoginLog[]
  contentItemsCreated ContentLibraryItem[] @relation("ContentCreatedBy")
  contentItemsUpdated ContentLibraryItem[] @relation("ContentUpdatedBy")

  // Support Tickets
  supportTickets  SupportTicket[] @relation("UserTickets")
  resolvedTickets SupportTicket[] @relation("ResolvedTickets")

  // Reviews
  staffReviews    ClientReview[]  @relation("StaffReviews")
}

// ─── Staff & Client Profiles ─────────────────────────────────────────────────

model StaffProfile {
  id                 String   @id @default(uuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  location           String?
  locationLat        Float?
  locationLng        Float?
  skills             String[]
  hourlyRate         Float    @default(0)
  rating             Float    @default(0)
  totalEvents        Int      @default(0)
  availabilityStatus String   @default("available") // available, busy, off
  isActive           Boolean  @default(true)
  joinDate           DateTime @default(now())
  emergencyContact   String?
  emergencyPhone     String?
  bankAccountInfo    String? // Encrypted
  taxId              String? // SSN/EIN (Encrypted)

  // Device lock – one staff = one device
  registeredDeviceId    String?  // unique device fingerprint
  registeredDeviceName  String?  // e.g. "Pixel 7 Pro"
  registeredDeviceModel String?  // e.g. "Pixel 7 Pro"
  registeredDeviceBrand String?  // e.g. "Google"
  registeredDeviceOS    String?  // e.g. "Android 14"
  deviceLockedAt        DateTime? // when device was registered
  deviceChangeRequested Boolean  @default(false)
  deviceChangeReason    String?

  unavailabilities StaffUnavailability[]
}

model StaffUnavailability {
  id             String       @id @default(uuid())
  staffProfileId String
  staffProfile   StaffProfile @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)
  startDate      DateTime
  endDate        DateTime
  startTime      String?      // e.g. "09:00"
  endTime        String?      // e.g. "17:00"
  reason         String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model ClientProfile {
  id           String  @id @default(uuid())
  userId       String  @unique
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         String  @default("corporate") // corporate, individual, venue
  company      String?
  address      String?
  creditLimit  Float?
  paymentTerms String? // NET30, NET60, etc.
  totalEvents  Int     @default(0)
  totalSpent   Float   @default(0)
  rating       Float   @default(0)
  isActive     Boolean @default(true)

  events   Event[]   @relation("ClientEvents")
  invoices Invoice[]
  reviews  ClientReview[]
}

// ─── Client Reviews ─────────────────────────────────────────────────────────

model ClientReview {
  id        String   @id @default(uuid())
  clientId  String
  client    ClientProfile @relation(fields: [clientId], references: [id])
  staffId   String
  staff     User     @relation("StaffReviews", fields: [staffId], references: [id])
  eventId   String?
  event     Event?   @relation(fields: [eventId], references: [id])
  rating    Int      // 1 to 5 stars
  feedback  String?
  createdAt DateTime @default(now())
}

// ─── Favorite Staff (Client → Staff bookmark list) ──────────────────────────

model FavoriteStaff {
  id        String   @id @default(uuid())
  clientId  String
  client    User     @relation("ClientFavorites", fields: [clientId], references: [id])
  staffId   String
  staff     User     @relation("StaffFavorited", fields: [staffId], references: [id])
  notes     String?
  createdAt DateTime @default(now())

  @@unique([clientId, staffId])
}

// ─── Event & Shift Operations ────────────────────────────────────────────────

model Event {
  id        String        @id @default(uuid())
  clientId  String
  client    ClientProfile @relation("ClientEvents", fields: [clientId], references: [id])
  managerId String?
  manager   User?         @relation("EventManager", fields: [managerId], references: [id])

  title               String
  description         String
  eventType           String? // Corporate, Wedding, Concert, etc.
  venue               String?
  date                DateTime
  endDate             DateTime?
  startTime           String
  endTime             String
  location            String
  locationLat         Float?
  locationLng         Float?
  geofencePolygon     Json?   // [[lat,lng],...] — manual or OSM polygon
  geofenceRadius      Float?  // metres — circle fallback; null = adaptive
  status              EventStatus @default(PENDING)
  staffRequired       Int
  guestCount          Int?
  budget              Float       @default(0)
  deposit             Float       @default(0)
  tips                Float       @default(0)
  specialRequirements String?
  dressCode           String?
  contactOnSite       String?
  contactOnSitePhone  String?
  staffCosts          Float       @default(0)
  travelFee           Float       @default(0)
  platformFee         Float       @default(0)
  additionalFees      Float       @default(0)
  adminNotes          String?     @db.Text
  isMultiDay          Boolean     @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shifts        Shift[]
  invoices      Invoice[]
  incidents     IncidentReport[]
  conversations Conversation[]
  clientReviews ClientReview[]
  eventDates    EventDate[]
  surveys       Survey[]
}

model EventDate {
  id        String   @id @default(uuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  date      DateTime
  startTime String
  endTime   String
  createdAt DateTime @default(now())
}

model Shift {
  id      String @id @default(uuid())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  staffId String
  staff   User   @relation(fields: [staffId], references: [id])

  date            DateTime
  startTime       String
  endTime         String
  reportTime      String?   // When staff should arrive (may differ from paid startTime)
  status          ShiftStatus @default(PENDING)
  role            String? // Bartender, Server, Security, etc.
  hourlyRate      Float       @default(0)
  guaranteedHours Float? // Minimum hours guaranteed (MoM item)

  // Clock tracking
  clockIn    DateTime?
  clockOut   DateTime?
  location   String?
  totalHours Float?
  totalPay   Float?

  // Travel permission (Admin must enable per shift)
  travelEnabled     Boolean   @default(false)

  // Travel tracking (Uber-like flow per MoM)
  travelStartTime   DateTime? // Staff tapped "Start Travel"
  travelArrivalTime DateTime? // Staff arrived at venue
  travelHomeStart   DateTime? // Staff tapped "Travel Home"
  travelHomeEnd     DateTime? // Staff arrived home
  travelDuration    Float? // Total travel minutes
  travelLat         Float? // Last known lat during travel
  travelLng         Float? // Last known lng during travel

  // Parking (MoM parking receipt)
  parkingAmount     Float?
  parkingReceiptUrl String?

  // Tips
  tipsReceived Float @default(0)

  // Device info captured during shift actions
  deviceId    String? // unique device fingerprint
  deviceName  String? // e.g. "Pixel 7 Pro"
  deviceModel String? // e.g. "Pixel 7 Pro"
  deviceBrand String? // e.g. "Google"
  deviceOS    String? // e.g. "Android 14"
  deviceIP    String? // IP address at time of action

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  timesheet Timesheet?
  breaks    ShiftBreak[]
}

model ShiftBreak {
  id              String    @id @default(uuid())
  shiftId         String
  shift           Shift     @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  startTime       DateTime  @default(now())
  endTime         DateTime?
  durationMinutes Float?
}

// ─── HR & Recruitment ────────────────────────────────────────────────────────

model Application {
  id          String   @id @default(uuid())
  applicantId String?
  applicant   User?    @relation(fields: [applicantId], references: [id])
  position    String? // Role they're applying for
  status      String   @default("PENDING") // PENDING, REVIEWING, INTERVIEWED, HIRED, REJECTED
  resumeUrl   String?
  coverLetter String?
  source      String? // QR code, website, referral, careers_page
  notes       String?
  // Public applicant fields (when no User account exists)
  applicantName  String?
  applicantEmail String?
  applicantPhone String?
  jobPostingId   String? // Link to specific JobPosting
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Certification {
  id          String    @id @default(uuid())
  staffId     String
  staff       User      @relation("StaffCertifications", fields: [staffId], references: [id])
  name        String
  issuer      String?
  issueDate   DateTime?
  expiryDate  DateTime?
  documentUrl String?
  verified    Boolean   @default(false)
  createdAt   DateTime  @default(now())
}

model Interview {
  id            String   @id @default(uuid())
  candidateId   String
  candidate     User     @relation(fields: [candidateId], references: [id])
  interviewerId String?
  interviewer   User?    @relation("Interviewer", fields: [interviewerId], references: [id])
  scheduledAt   DateTime
  location      String? // In-person or Virtual link
  status        String   @default("SCHEDULED") // SCHEDULED, COMPLETED, CANCELLED, NO_SHOW
  notes         String?
  rating        Int?
  createdAt     DateTime @default(now())
}

model JobPosting {
  id                String   @id @default(uuid())
  title             String
  department        String
  type              String // full-time, part-time, contractor, seasonal
  location          String
  salaryRange       String
  status            String   @default("active") // active, paused, closed
  description       String
  requirements      String[]
  responsibilities  String[]
  benefits          String[]
  applicationsCount Int      @default(0)
  viewsCount        Int      @default(0)
  postedDate        DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Assessment {
  id             String    @id @default(uuid())
  candidateId    String
  candidate      User      @relation("CandidateAssessments", fields: [candidateId], references: [id])
  candidateName  String // cached
  position       String
  type           String // personality, skills, both
  status         String    @default("pending") // pending, scheduled, completed
  overallScore   Float     @default(0)
  communication  Float     @default(0)
  teamwork       Float     @default(0)
  problemSolving Float     @default(0)
  leadership     Float     @default(0)
  technical      Float     @default(0)
  completedDate  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// ─── Document Management (Onboarding & Compliance) ──────────────────────────

model Document {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  category   String // ID, CONTRACT, TAX_FORM, CERTIFICATION, NDA, OTHER
  fileUrl    String
  fileSize   Int?
  mimeType   String?
  status     String    @default("PENDING") // PENDING, VERIFIED, REJECTED, EXPIRED
  expiresAt  DateTime?
  verifiedAt DateTime?
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

// ─── Financial Models ────────────────────────────────────────────────────────

model Timesheet {
  id                String    @id @default(uuid())
  shiftId           String    @unique
  shift             Shift     @relation(fields: [shiftId], references: [id])
  staffId           String
  staff             User      @relation(fields: [staffId], references: [id])
  clockInTime       DateTime
  clockOutTime      DateTime?
  totalHours        Float?
  regularHours      Float?
  additionalWork    Float? // Replaces 'overtime' per MoM
  breakMinutes      Float?
  driveTime         Float? // Travel time in hours
  parkingAmount     Float? // Parking reimbursement
  tipsAmount        Float?
  workersCompRate   Float? // Workers comp percentage
  workersCompAmount Float? // Calculated workers comp deduction
  status            String    @default("PENDING") // PENDING, APPROVED, REJECTED
  approvedById      String?
  approvedBy        User?     @relation("TimesheetApprover", fields: [approvedById], references: [id])
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model Invoice {
  id            String        @id @default(uuid())
  invoiceNumber String        @unique @default(uuid()) // Human-readable invoice #
  clientId      String
  client        ClientProfile @relation(fields: [clientId], references: [id])
  eventId       String?
  event         Event?        @relation(fields: [eventId], references: [id])
  subtotal      Float         @default(0)
  taxRate       Float         @default(0)
  taxAmount     Float         @default(0)
  amount        Float
  status        String        @default("DRAFT") // DRAFT, SENT, PAID, OVERDUE, CANCELLED, AWAITING_VERIFICATION
  dueDate       DateTime
  paidDate      DateTime?
  paymentMethod String?       // Bank Transfer, Wire, ACH, Credit Card, Check, Cash, Other
  paymentProofUrl String?     // URL to uploaded payment proof file
  paymentProofDate DateTime?  // When client submitted payment proof
  stripeId      String? // Payment gateway reference
  pdfUrl        String?
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  lineItems InvoiceLineItem[]
}

model InvoiceLineItem {
  id          String  @id @default(uuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Float
  unitPrice   Float
  amount      Float
}

model PayrollRun {
  id          String   @id @default(uuid())
  periodStart DateTime
  periodEnd   DateTime
  processedBy String
  processor   User     @relation("PayrollProcessor", fields: [processedBy], references: [id])
  totalAmount Float
  status      String   @default("DRAFT") // DRAFT, PROCESSING, COMPLETED, CANCELLED
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items PayrollItem[]
}

model PayrollItem {
  id                   String     @id @default(uuid())
  payrollRunId         String
  payrollRun           PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  staffId              String
  staffName            String
  regularHours         Float      @default(0)
  additionalHours      Float      @default(0) // "Additional Work" hours
  hourlyRate           Float      @default(0)
  regularPay           Float      @default(0)
  additionalPay        Float      @default(0)
  driveTimePay         Float      @default(0)
  parkingReimbursement Float      @default(0)
  tipsAmount           Float      @default(0)
  workersCompDeduction Float      @default(0)
  otherDeductions      Float      @default(0)
  grossPay             Float      @default(0)
  netPay               Float      @default(0)
  notes                String?
}

// ─── Operations ──────────────────────────────────────────────────────────────

model IncidentReport {
  id              String   @id @default(uuid())
  eventId         String?
  event           Event?   @relation(fields: [eventId], references: [id])
  reportedBy      String
  reporter        User     @relation("IncidentReporter", fields: [reportedBy], references: [id])
  title           String   @default("")
  type            String   @default("other") // injury, property-damage, complaint, safety, theft, other
  severity        String   @default("LOW") // LOW, MEDIUM, HIGH, CRITICAL
  status          String   @default("OPEN") // OPEN, INVESTIGATING, RESOLVED, CLOSED
  description     String
  location        String?
  involvedParties String[] @default([])
  witnesses       String[] @default([])
  actionsTaken    String?
  resolution      String?
  followUpRequired Boolean @default(false)
  notes           Json     @default("[]") // Array of { id, author, content, timestamp }
  timeline        Json     @default("[]") // Array of { id, action, by, timestamp, details }
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── Equipment & Inventory ──────────────────────────────────────────────────

model EquipmentItem {
  id            String   @id @default(uuid())
  name          String
  category      String   @default("supplies") // uniform, equipment, supplies
  sku           String   @unique
  quantity      Int      @default(0)
  minStock      Int      @default(0)
  unit          String   @default("pieces")
  cost          Float    @default(0)
  location      String?
  lastRestocked DateTime?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  assignments EquipmentAssignment[]
}

model EquipmentAssignment {
  id           String    @id @default(uuid())
  itemId       String
  item         EquipmentItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  staffId      String
  staffName    String
  quantity     Int       @default(1)
  assignedDate DateTime  @default(now())
  returnDate   DateTime?
  status       String    @default("checked-out") // checked-out, returned, damaged, lost
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// ─── Quality Assurance Surveys ──────────────────────────────────────────────

model Survey {
  id              String    @id @default(uuid())
  eventId         String
  event           Event     @relation(fields: [eventId], references: [id])
  clientName      String
  clientEmail     String?
  surveyStatus    String    @default("not_sent") // not_sent, sent, completed
  sentDate        DateTime?
  completedDate   DateTime?
  message         String?
  overallRating   Float?
  responses       Json?     // { staffQuality, professionalism, punctuality, communication, valueForMoney }
  comments        String?
  wouldRecommend  Boolean?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ─── Chat & Communication ────────────────────────────────────────────────────

model Conversation {
  id            String   @id @default(uuid())
  isGroup       Boolean  @default(false)
  name          String? // For group chats
  eventId       String? // Optional link to event group chat
  event         Event?   @relation(fields: [eventId], references: [id])
  lastMessageAt DateTime @default(now())

  participants ConversationParticipant[]
  messages     Message[]
  createdAt    DateTime                  @default(now())
}

model ConversationParticipant {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  joinedAt       DateTime     @default(now())
  lastReadAt     DateTime     @default(now())

  @@unique([conversationId, userId])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id])
  content        String
  type           String       @default("TEXT") // TEXT, FILE, IMAGE
  fileUrl        String?
  fileName       String?
  isSystem       Boolean      @default(false)
  createdAt      DateTime     @default(now())
}

// ─── Notifications ───────────────────────────────────────────────────────────

model Notification {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title          String
  message        String
  type           String // 'shift', 'payment', 'reminder', 'schedule', 'review', 'training', 'profile', 'system', 'message', 'ticket'
  unread         Boolean  @default(true)
  priority       String   @default("medium") // 'high', 'medium', 'low'
  actionRequired Boolean  @default(false)
  category       String?
  data           Json? // For storing related IDs or additional context
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
  @@index([createdAt])
}

// ─── Pricing Configuration ───────────────────────────────────────────────────

model PricingConfig {
  id                    String   @id @default(uuid())
  platformFeePercentage Float    @default(15)
  minimumHours          Float    @default(5)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  tierRates       TierRate[]
  multiplierRules MultiplierRule[]
  travelFeeRules  TravelFeeRule[]
}

model TierRate {
  id              String        @id @default(uuid())
  pricingConfigId String
  pricingConfig   PricingConfig @relation(fields: [pricingConfigId], references: [id], onDelete: Cascade)
  role            String
  junior          Float         @default(0)
  standard        Float         @default(0)
  premium         Float         @default(0)
  elite           Float         @default(0)

  @@unique([pricingConfigId, role])
}

model MultiplierRule {
  id              String        @id @default(uuid())
  pricingConfigId String
  pricingConfig   PricingConfig @relation(fields: [pricingConfigId], references: [id], onDelete: Cascade)
  name            String
  type            String
  percentage      Float
  enabled         Boolean       @default(true)
  description     String
}

model TravelFeeRule {
  id              String        @id @default(uuid())
  pricingConfigId String
  pricingConfig   PricingConfig @relation(fields: [pricingConfigId], references: [id], onDelete: Cascade)
  minMiles        Float
  maxMiles        Float
  fee             Float
}

// ─── Integrations ─────────────────────────────────────────────────────────────

model Integration {
  id          String    @id @default(uuid())
  key         String    @unique // e.g. "quickbooks", "slack"
  name        String
  category    String // accounting | payroll | calendar | communication | storage | documents | automation
  description String
  isActive    Boolean   @default(false)
  config      String? // JSON: api keys, tokens, settings (encrypted at app layer)
  lastSyncAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ─── User Preferences ─────────────────────────────────────────────────────────
model UserPreferences {
  id                String   @id @default(uuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  notificationPrefs Json     @default("{}") // email/sms/push/marketing + type toggles
  systemPrefs       Json     @default("{}") // language/timezone/currency/autoClockOut/geoLocation/twoFactor
  updatedAt         DateTime @updatedAt
}

// ─── Company Settings ──────────────────────────────────────────────────────────
model CompanySettings {
  id        String   @id @default(uuid())
  key       String   @unique @default("default")
  data      Json     @default("{}") // company info + billing prefs
  updatedAt DateTime @updatedAt
}

// ─── Role Permission Configuration ────────────────────────────────────────────
model RolePermissionConfig {
  id          String   @id @default(uuid())
  role        Role     @unique
  permissions String[]
  updatedAt   DateTime @updatedAt
}

// ─── Database Backup Logs ──────────────────────────────────────────────────────
model BackupLog {
  id          String   @id @default(uuid())
  type        String // "FULL" | "INCREMENTAL"
  status      String // "COMPLETED" | "FAILED" | "IN_PROGRESS"
  sizeBytes   BigInt?
  filePath    String?
  errorMsg    String?
  initiatedBy String? // userId of admin who triggered it, or "SYSTEM"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Login Activity Log ───────────────────────────────────────────────────────
model LoginLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  success   Boolean
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

// ─── Help & Support ───────────────────────────────────────────────────────────

model SupportTicket {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation("UserTickets", fields: [userId], references: [id], onDelete: Cascade)
  subject         String
  category        String
  message         String
  status          String   @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  resolutionNotes String?
  resolvedById    String?
  resolvedBy      User?    @relation("ResolvedTickets", fields: [resolvedById], references: [id])
  updatedAt       DateTime @updatedAt
}

// ─── Content Library ─────────────────────────────────────────────────────────

model ContentLibraryItem {
  id              String   @id @default(uuid())
  slug            String   @unique
  title           String
  description     String
  body            String?  @db.Text
  section         String   // RESOURCE, DOCUMENTATION, TRAINING
  kind            String   // LINK, GUIDE, VIDEO, POLICY, COURSE
  category        String
  icon            String?
  color           String?
  actionLabel     String?
  url             String?
  pages           Int?
  durationMinutes Int?
  modules         Int?
  required        Boolean  @default(false)
  instructor      String?
  audiences       String[] @default(["STAFF"])
  isPublished     Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdById     String?
  createdBy       User?    @relation("ContentCreatedBy", fields: [createdById], references: [id])
  updatedById     String?
  updatedBy       User?    @relation("ContentUpdatedBy", fields: [updatedById], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([section, kind, isPublished, sortOrder])
}
